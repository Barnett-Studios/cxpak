#!/usr/bin/env bash
set -euo pipefail

# Find cxpak on PATH. If not found, install via brew or cargo.

if command -v cxpak >/dev/null 2>&1; then
    echo "$(command -v cxpak)"
    exit 0
fi

# Not on PATH — try to install

if command -v brew >/dev/null 2>&1; then
    echo "cxpak: not found, installing via Homebrew..." >&2
    brew tap Barnett-Studios/tap 2>&1 >&2
    brew install cxpak 2>&1 >&2
    if command -v cxpak >/dev/null 2>&1; then
        echo "$(command -v cxpak)"
        exit 0
    fi
fi

if command -v cargo >/dev/null 2>&1; then
    echo "cxpak: not found, installing via cargo..." >&2
    cargo install cxpak 2>&1 >&2
    if command -v cxpak >/dev/null 2>&1; then
        echo "$(command -v cxpak)"
        exit 0
    fi
fi

echo "cxpak: not found and could not install automatically." >&2
echo "" >&2
echo "Install manually:" >&2
echo "  brew tap Barnett-Studios/tap && brew install cxpak" >&2
echo "  cargo install cxpak" >&2
exit 1
